# macOS legt diese Dateien automatisch an; sie haben keinen Projektwert.
.DS_Store
**/.DS_Store

# Geheimnisse und lokale Umgebung dürfen niemals versioniert werden.
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Lokale Zugangsdaten-Dateien NIEMALS versionieren.
# Jede Projektkopie benennt ihre Zugangsdaten-Datei individuell und ergänzt sie hier.
*ZUGANGSDATEN*.md
*zugangsdaten*.md

# Lokale PHP-Konfiguration (enthält Secrets).
**/config.php

# Migrationsskripte können DB-Zugangsdaten enthalten.
**/migration/migrieren.php

# Abhängigkeiten und Build-Ausgaben werden reproduzierbar erzeugt.
node_modules/
**/node_modules/
dist/
build/
coverage/

# Laufzeit- und Diagnoseausgaben gehören nicht ins Repository.
*.log
logs/

# Backups bleiben lokal, außer die bewusst gepflegte README.
BACKUPS/*
!BACKUPS/README.md

# Editor- und Betriebssystem-Zwischenstände.
.vscode/
.idea/
*.swp
*.swo

# Lokal-only: Playtests und DB-Backups nie versionieren
PlayTest/
**/PlayTest/
*.sql
*.sql.gz
*.dump
